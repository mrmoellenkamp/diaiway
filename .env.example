# ─── Timezone (Mitteleuropa/Berlin, CET/CEST) ───────────────────────────────────
# Server nutzt Europe/Berlin für Datum/Uhrzeit. Für Vercel: in Project Settings → Environment Variables hinzufügen.
TZ=Europe/Berlin

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon / Supabase / Railway / local)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/diaiway"

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production-min-32-chars"

# ─── E-Mail (Ionos SMTP) ──────────────────────────────────────────────────────
# Unterstützt auch EMAIL_SERVER_* (Vercel-Konvention)
SMTP_HOST="smtp.ionos.de"
SMTP_PORT="587"
SMTP_USER="info@diaiway.de"
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="info@diaiway.de"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Google Gemini (AI Chat) ──────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY="AIza..."

# ─── Google Cloud Vision (Safety Enforcement) ─────────────────────────────────
# Pre-Check vor Daily-Join, Live-Monitoring. Ohne Key wird Prüfung übersprungen.
GOOGLE_CLOUD_VISION_API_KEY=""

# ─── Daily.co (Video Calls) ──────────────────────────────────────────────────
DAILY_API_KEY="..."
NEXT_PUBLIC_DAILY_DOMAIN="https://your-domain.daily.co"

# ─── Vercel Blob (Bilder, Safety Incidents) ───────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# ─── Web Push (Benachrichtigungen) ───────────────────────────────────────────
# VAPID keys generieren: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey);console.log('NEXT_PUBLIC_VAPID_PUBLIC_KEY='+k.publicKey);"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─── Admin Seeding ───────────────────────────────────────────────────────────
ADMIN_PASSWORD="change-this-secret"

# ─── Wallet Cron (24h-Freigabe) ──────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet. Vercel Cron sendet: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ─── E2E (Playwright) ────────────────────────────────────────────────────────
# E2E_ENABLED="true"
# PLAYWRIGHT_TEST_EMAIL="test@example.com"
# PLAYWRIGHT_TEST_PASSWORD="Test123!"
# PLAYWRIGHT_BOOKING_ID="<confirmed booking id>"
# PLAYWRIGHT_TAKUMI_ID="<takumi id>"
