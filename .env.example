# ─── Timezone (Mitteleuropa/Berlin, CET/CEST) ───────────────────────────────────
# Server nutzt Europe/Berlin für Datum/Uhrzeit. Für Vercel: in Project Settings → Environment Variables hinzufügen.
TZ=Europe/Berlin

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon / Supabase / Railway / local)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/diaiway"

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production-min-32-chars"

# ─── E-Mail (Ionos SMTP) ──────────────────────────────────────────────────────
SMTP_HOST="smtp.ionos.de"
SMTP_PORT="587"
SMTP_USER="info@diaiway.de"
SMTP_PASSWORD="your-smtp-password"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Google Gemini (AI Chat) ──────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY="AIza..."

# ─── Google Cloud Vision (Bild-Safety) ────────────────────────────────────────
# SafeSearch: Prüft Uploads auf explizite Inhalte. Ohne Key wird die Prüfung übersprungen.
GOOGLE_CLOUD_VISION_API_KEY=""

# ─── Google Cloud Vision (Bild-Safety) ─────────────────────────────────────────
# API-Key mit aktivierter Vision API. Prüft Uploads auf explizite Inhalte (SafeSearch).
# Ohne Key: Prüfung wird übersprungen.
# GOOGLE_CLOUD_VISION_API_KEY="AIza..."

# ─── Daily.co (Video Calls) ──────────────────────────────────────────────────
DAILY_API_KEY="..."
NEXT_PUBLIC_DAILY_DOMAIN="https://your-domain.daily.co"

# ─── Vercel Blob (File Uploads) ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# ─── Web Push (Neue Nachrichten) ─────────────────────────────────────────────
# VAPID keys für Push-Benachrichtigungen. Generieren mit: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey);"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─── Admin Seeding ────────────────────────────────────────────────────────────
# Used by POST /api/auth/seed-admin to protect the endpoint
ADMIN_PASSWORD="change-this-secret"

# ─── Wallet Cron ──────────────────────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet. Vercel Cron sendet: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ─── Wallet Cron ──────────────────────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet. Vercel Cron sendet: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ─── Wallet Cron ─────────────────────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet (24h-Freigabe). Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ─── Wallet Cron ──────────────────────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet. Vercel Cron sendet: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ─── Wallet Cron (24h-Freigabe) ────────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet. Vercel Cron sendet: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ─── Wallet Cron ──────────────────────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet. Vercel Cron sendet: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ─── Wallet Cron ──────────────────────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet. Bei Vercel Cron automatisch gesetzt.
CRON_SECRET=""

# ─── Timezone ──────────────────────────────────────────────────────────────────
# Europe/Berlin = CET (Winter) / CEST (Sommer). Für Vercel: in Project Settings → Environment Variables hinzufügen.
TZ="Europe/Berlin"

# ─── Billing / Belege ─────────────────────────────────────────────────────────
# Absender für Rechnungen, Gutschriften, Stornos
# BILLING_COMPANY_NAME="JM faircharge UG"
# BILLING_STREET="Musterstraße 1"
# BILLING_ZIP="12345"
# BILLING_CITY="Berlin"
# BILLING_COUNTRY="Deutschland"
# BILLING_VAT_ID=""
# BILLING_IBAN=""
# BILLING_BIC=""
# E-Rechnung ZUGFeRD (B2B-Pflicht ab 2025): factur-x.xml in PDF einbetten
# BILLING_ZUGFERD_ENABLED="true"

# ─── Playwright E2E (diaiway Safety Enforcement) ────────────────────────────────
# PLAYWRIGHT_TEST_EMAIL="test@example.com"
# PLAYWRIGHT_TEST_PASSWORD="Test123!"
# PLAYWRIGHT_BOOKING_ID="<confirmed booking id>"
# PLAYWRIGHT_TAKUMI_ID="<takumi id for 7-day test>"

# ─── Timezone ──────────────────────────────────────────────────────────────────
# Server uses Europe/Berlin (CET/CEST) for date/time. Required for correct slot comparisons.
# Add TZ=Europe/Berlin in Vercel Project Settings → Environment Variables.
TZ=Europe/Berlin
