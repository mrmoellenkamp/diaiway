# ─── Timezone (Mitteleuropa/Berlin, CET/CEST) ───────────────────────────────────
# Server nutzt Europe/Berlin für Datum/Uhrzeit. Für Vercel: in Project Settings → Environment Variables hinzufügen.
TZ=Europe/Berlin

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (provider-unabhaengig, z. B. Prisma Postgres / Supabase / Railway / local)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
#
# Serverless (Vercel): Nutze wenn möglich den DB-Pooler, um Connection Exhaustion zu vermeiden.
#   DATABASE_URL: Runtime-URL (idealerweise Pooler) mit ?pgbouncer=true&connection_limit=1
#   DIRECT_URL:   Direkte DB-URL (ohne Pooler) — für Migrationen erforderlich
# Beispiel (provider-neutral, Platzhalter):
#   DATABASE_URL="postgresql://user:pass@POOLER_HOST:5432/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://user:pass@DIRECT_HOST:5432/DBNAME?sslmode=require"
# Lokal ohne Pooler: DIRECT_URL = dieselbe Zeichenkette wie DATABASE_URL.
#   Alternativ weglassen: npm-Skripte (postinstall, build, db:migrate:deploy) nutzen scripts/prisma-runner.mjs
#   und setzen DIRECT_URL := DATABASE_URL beim Aufruf.
#
DATABASE_URL="postgresql://postgres:password@localhost:5432/diaiway"
DIRECT_URL="postgresql://postgres:password@localhost:5432/diaiway"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Lokal: exakt wie im Browser (Port = next dev, hier 3001 laut package.json „dev“)
NEXTAUTH_URL="http://localhost:3001"
# Auth.js v5: falls gesetzt, muss lokal dasselbe sein wie die URL im Browser (sonst Redirects zur falschen Domain)
# AUTH_URL="http://localhost:3001"
# Wenn NEXTAUTH_URL / AUTH_URL auf https://diaiway.com zeigen, springt der Login oft auf Live.
# Production (Vercel): exakt kanonische URL, z. B. https://diaiway.com — ohne www, ohne Slash am Ende
# NEXTAUTH_URL="https://diaiway.com"
NEXTAUTH_SECRET="change-me-in-production-min-32-chars"
# Siehe docs/DEPLOYMENT-AUTH.md (Safari / Session-Cookies)

# ─── E-Mail (Ionos SMTP) ──────────────────────────────────────────────────────
# Unterstützt auch EMAIL_SERVER_* (Vercel-Konvention)
SMTP_HOST="smtp.ionos.de"
SMTP_PORT="587"
SMTP_USER="info@diaiway.de"
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="info@diaiway.de"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Google Gemini (AI Chat) ──────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY="AIza..."

# ─── Google Cloud Vision (Safety Enforcement) ─────────────────────────────────
# Live-Monitoring, Incident-Speicherung. Ohne Key wird Prüfung übersprungen.
GOOGLE_CLOUD_VISION_API_KEY=""

# ─── Vercel Blob (Bilder, Safety Incidents) ───────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# ─── Cloudmersive (Secure File Exchange – Virenscan) ───────────────────────────
CLOUDMERSIVE_API_KEY=""

# ─── Web Push (Benachrichtigungen) ───────────────────────────────────────────
# VAPID keys generieren: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey);console.log('NEXT_PUBLIC_VAPID_PUBLIC_KEY='+k.publicKey);"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─── Admin Seeding ───────────────────────────────────────────────────────────
ADMIN_PASSWORD="change-this-secret"

# ─── Wallet Cron (24h-Freigabe) ──────────────────────────────────────────────
# Optional: Schützt GET /api/cron/release-wallet. Vercel Cron sendet: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ─── E2E (Playwright) ────────────────────────────────────────────────────────
# E2E_ENABLED="true"
# PLAYWRIGHT_TEST_EMAIL="test@example.com"
# PLAYWRIGHT_TEST_PASSWORD="Test123!"
# PLAYWRIGHT_BOOKING_ID="<confirmed booking id>"
# PLAYWRIGHT_TAKUMI_ID="<takumi id>"

# ─── Beta-Landing (/beta/de) ─────────────────────────────────────────────────
# Optional: „Nachricht schreiben“-Button (mailto mit Betreff). Sonst Fallback im Code.
# NEXT_PUBLIC_BETA_MAILTO="mailto:admin@diaiway.com?subject=Beta-Test%20diAiway"
