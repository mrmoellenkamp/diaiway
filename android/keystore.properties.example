# Kopiere nach android/keystore.properties und trage echte Werte ein.
# Datei keystore.properties ist in .gitignore — nicht ins Repository committen.
#
# storeFile: relativ zum Modul android/app/ (z. B. release.keystore im Ordner app/)
storeFile=release.keystore
storePassword=HIER_GEHEIMES_PASSWORT
keyAlias=diaiway
keyPassword=HIER_GEHEIMES_PASSWORT
