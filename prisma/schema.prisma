// Prisma Schema — diAiway
// Provider: PostgreSQL (Neon / Supabase / Railway etc.)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  user
  admin
}

enum AppRole {
  shugyo
  takumi
}

enum UserStatus {
  active
  paused
}

enum BookingStatus {
  pending
  confirmed
  active
  completed
  declined
  cancelled
}

enum PaymentStatus {
  unpaid
  pending
  paid
  refunded
  failed
}

enum CallType {
  VIDEO
  VOICE
}

enum TransactionStatus {
  PENDING    // @deprecated Legacy, wird als AUTHORIZED behandelt
  COMPLETED  // @deprecated Legacy, wird als CAPTURED behandelt
  AUTHORIZED // Hold: Stripe authorized, Geld reserviert, noch nicht eingezogen
  CAPTURED   // Beleg erstellt, Takumi-Guthaben gutgeschrieben
  CANCELED   // Storno vor Capture (Autorisierung verfällt)
  REFUNDED   // Storno nach Capture (SR/SG-Beleg erforderlich)
  ON_HOLD    // diaiway Safety: Pause wegen SafetyReport, manuelle Prüfung nötig
}

// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  password         String
  role             UserRole   @default(user)
  appRole          AppRole    @default(shugyo)
  status           UserStatus @default(active)
  isBanned         Boolean    @default(false)  // diaiway Safety: dauerhaft gesperrt
  image            String     @default("")
  favorites        String[]   // array of Expert IDs
  resetToken       String?
  resetTokenExpiry DateTime?

  // Kundennummer für Belege (Format KD-10000)
  customerNumber   String?   @unique

  // Wallet (für Takumis: Verdienst; für Shugyos: Guthaben aus Rückerstattungen)
  balance          Int       @default(0)  // EUR cents
  pendingBalance   Int       @default(0)  // EUR cents, bei Hold-Modell nicht genutzt (Stripe hält)

  // Shugyo: Bei Rückerstattung — "payout" = Auszahlung auf Karte, "wallet" = Guthaben
  refundPreference String    @default("payout")

  // Rechnungsdaten / billingDetails: { type: "privat"|"unternehmen", ... }
  // privat: fullName, street, houseNumber, zip, city, country, email
  // unternehmen: + companyName, legalForm?, vatId?, taxNumber?, kleinunternehmer (§19 UStG)
  invoiceData      Json?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  expert              Expert?
  bookings            Booking[]         @relation("UserBookings")
  availability        Availability?
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  transactionsPaid   Transaction[]     @relation("UserPaidTransactions")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String   // public key
  auth      String   // auth secret
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
}

model Expert {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  name            String
  email           String   @default("")
  avatar          String
  categorySlug    String
  categoryName    String
  subcategory     String
  bio             String
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  sessionCount    Int      @default(0)
  responseTime    String   @default("< 5 Min")
  // Neues Pricing-Modell: Preis pro 15 Min (EUR)
  priceVideo15Min Decimal  @default(0) @db.Decimal(10, 2)
  priceVoice15Min Decimal  @default(0) @db.Decimal(10, 2)
  pricePerSession Int?     // Legacy: EUR pro 30 Min, Fallback wenn neue Preise fehlen
  isLive          Boolean  @default(false)
  isPro           Boolean  @default(false)
  verified        Boolean  @default(false)
  portfolio       String[]
  joinedDate      String
  imageUrl        String   @default("")
  matchRate       Int      @default(0)
  // Social media links stored as JSON: { instagram, tiktok, facebook, youtube, linkedin, x, website }
  socialLinks     Json     @default("{}")
  // Cancellation policy: { freeHours: number, feePercent: number }
  // freeHours = free cancellation up to X hours before session
  // feePercent = % of booking fee retained if cancelled after free window (0–100)
  cancelPolicy    Json     @default("{\"freeHours\":24,\"feePercent\":0}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Stripe Connect für Payout-on-Demand (Takumi muss verknüpft haben)
  stripeConnectAccountId String?

  // Relations
  bookings    Booking[]
  reviews     Review[]
  transactions Transaction[] @relation("ExpertTransactions")
}

model Booking {
  id                    String        @id @default(cuid())
  expertId              String
  expert                Expert        @relation(fields: [expertId], references: [id])
  expertName            String
  expertEmail           String        @default("")
  userId                String
  user                  User          @relation("UserBookings", fields: [userId], references: [id])
  userName              String
  userEmail             String

  date                  String        // YYYY-MM-DD
  startTime             String        // HH:mm
  endTime               String        // HH:mm
  status                BookingStatus @default(pending)
  callType              CallType      @default(VIDEO)  // VIDEO oder VOICE
  totalPrice            Decimal?      @db.Decimal(10, 2)  // Fixierter Preis bei Buchung (EUR)
  price                 Int?          // Legacy: EUR, Fallback für Bestandsbuchungen
  note                  String        @default("")
  statusToken           String        @unique

  // Video session
  dailyRoomUrl          String        @default("")
  sessionStartedAt      DateTime?
  sessionEndedAt        DateTime?
  sessionDuration       Int?          // minutes
  trialUsed             Boolean       @default(false)

  // diaiway Safety Enforcement: Pre-Call-Gateway-Zustimmung
  safetyAcceptedAt      DateTime?

  // Expert's rating of the user (Shugyo) — set when Takumi rates the booker
  expertRating    Float?
  expertReviewText String?

  // Payment
  paymentStatus         PaymentStatus @default(unpaid)
  stripeSessionId       String?
  stripePaymentIntentId String?
  paidAt                DateTime?
  paidAmount            Int?          // EUR cents

  // Cancellation
  cancelledBy     String?    // "user" | "expert"
  cancelFeeAmount Int?       // EUR cents retained (only if fee applies)
  cancelledAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction   Transaction?
  safetyReports SafetyReport[]

  @@index([expertId, date, status])
  @@index([userId])
  @@index([statusToken])
}

model Review {
  id        String   @id @default(cuid())
  expertId  String
  expert    Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  userId    String
  rating    Float
  text      String   @default("")
  createdAt DateTime @default(now())

  @@index([expertId])
}

model Availability {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // JSON fields: WeeklySlots, IWeeklyRule[], IDateException[]
  slots       Json     @default("{\"0\":[],\"1\":[],\"2\":[],\"3\":[],\"4\":[],\"5\":[],\"6\":[]}")
  yearlyRules Json     @default("[]")
  exceptions  Json     @default("[]")
  updatedAt   DateTime @updatedAt
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // booking_request | booking_confirmed | booking_declined | booking_question
  bookingId  String?
  title      String
  body       String   @default("")
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

model Transaction {
  id        String            @id @default(cuid())
  bookingId String            @unique
  booking   Booking           @relation(fields: [bookingId], references: [id])
  expertId  String
  expert    Expert            @relation("ExpertTransactions", fields: [expertId], references: [id])
  userId    String            // Shugyo (Zahler)
  user      User              @relation("UserPaidTransactions", fields: [userId], references: [id])
  totalAmount Int             // EUR cents (Bruttobetrag)
  platformFee  Int            // EUR cents (15 % Provision)
  netPayout   Int             // EUR cents (für Takumi)
  status    TransactionStatus @default(AUTHORIZED)
  invoiceNumber   String?     // RE-100001 (Rechnung an Shugyo)
  creditNoteNumber String?    // GS-100001 (Gutschrift an Takumi)
  invoicePdfUrl    String?    // Rechnung diaiway → Shugyo
  creditNotePdfUrl String?    // Gutschrift diaiway → Takumi
  // Storno-Belege bei REFUNDED
  stornoInvoiceNumber    String?  // SR-100001
  stornoCreditNoteNumber String?  // SG-100001
  stornoInvoicePdfUrl    String?
  stornoCreditNotePdfUrl String?
  completedAt      DateTime?  // Capture-Zeitpunkt
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([expertId])
  @@index([userId])
  @@index([status])
}

// diaiway Safety Enforcement: Meldungen aus dem Call
model SafetyReport {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reporterId  String   // User, der gemeldet hat
  reportedId  String   // User/Expert, gegen den gemeldet wurde (oder beide?)
  reporterRole String  // "shugyo" | "takumi"
  reason      String?  // optional: Kategorie oder Freitext
  details     String?  @default("")
  status      String   @default("pending")  // pending | reviewed | resolved
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([bookingId])
  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
}

// Atomare Vergabe fortlaufender Belegnummern (RE, GS, SR, SG) und Kundennummern (KD)
model InvoiceCounter {
  id    String   @id @default(cuid())
  type  String   @unique  // "RE" | "GS" | "SR" | "SG" | "KD"
  value Int      @default(0)
  updatedAt DateTime @updatedAt
}
