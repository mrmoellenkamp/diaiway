// Prisma Schema — diAiway
// Provider: PostgreSQL (provider-unabhaengig, z. B. Prisma Postgres / Supabase / Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // DIRECT_URL ist für Prisma-Pflicht. Ohne Pooler: in .env dieselbe URL wie DATABASE_URL eintragen.
  // Oder Migrationen nur über npm-Skript (setzt Fallback): `npm run db:migrate:deploy` — NICHT roh `npx prisma migrate deploy`.
  // Mit Pooler (Vercel/Neon): DIRECT_URL = direkte Postgres-URL (ohne PgBouncer).
  directUrl = env("DIRECT_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  user
  admin
}

enum AppRole {
  shugyo
  takumi
}

enum UserStatus {
  active
  paused
}

enum BookingStatus {
  pending
  confirmed
  active
  completed
  declined
  cancelled
  cancelled_in_handshake  // Session < 5 min: payment released, no charge
  instant_expired        // Instant: Takumi didn't answer within 60s; payment released
}

enum PaymentStatus {
  unpaid
  pending
  paid
  refunded
  failed
}

enum CallType {
  VIDEO
  VOICE
}

enum BookingMode {
  scheduled
  instant
}

enum SkillLevel {
  NEULING
  FORTGESCHRITTEN
  PROFI
}

enum CommunicationType {
  CHAT
  MAIL
}

enum TemplateCategory {
  SYSTEM
  BOOKING
}

enum VerificationSource {
  NONE
  STRIPE_CONNECT   // Takumi: Connect-Onboarding abgeschlossen
  STRIPE_PAYMENT   // Shugyo: Erste erfolgreiche Zahlung
  ACTIVITY         // Shugyo: 3 abgeschlossene Sessions (Case B)
  MANUAL           // Admin manuell verifiziert
}

// Instant-Connect: Takumi-Status für spontane Calls
enum LiveStatus {
  offline   // Nicht erreichbar
  available // Online, bereit für Instant-Call
  in_call   // Im Gespräch
  busy      // Beschäftigt (nicht verfügbar)
}

/// Takumi-Selbstregistrierung: Profilfreigabe durch Admin
enum TakumiProfileReviewStatus {
  draft            // Entwurf, nicht eingereicht
  pending_review   // Wartet auf Admin
  approved         // Öffentlich sichtbar (mit anderen Gates)
  rejected         // Abgelehnt, Hinweis an Nutzer
}

enum TransactionStatus {
  PENDING    // @deprecated Legacy, wird als AUTHORIZED behandelt
  COMPLETED  // @deprecated Legacy, wird als CAPTURED behandelt
  AUTHORIZED // Hold: Stripe authorized, Geld reserviert, noch nicht eingezogen
  CAPTURED   // Beleg erstellt, Takumi-Guthaben gutgeschrieben
  CANCELED   // Storno vor Capture (Autorisierung verfällt)
  REFUNDED   // Storno nach Capture (SR/SG-Beleg erforderlich)
  ON_HOLD    // diaiway Safety: Pause wegen SafetyReport, manuelle Prüfung nötig
}

// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  name             String
  username         String?    @unique  // Eindeutig, optional; Fallback: name_random
  email            String     @unique
  password         String
  role             UserRole   @default(user)
  appRole          AppRole    @default(shugyo)
  status           UserStatus @default(active)
  isBanned         Boolean    @default(false)  // diaiway Safety: dauerhaft gesperrt
  image            String     @default("")
  favorites        String[]   // array of Expert IDs
  resetToken       String?
  resetTokenExpiry DateTime?

  // E-Mail-Verifizierung (Double Opt-In)
  emailConfirmedAt          DateTime?
  emailVerificationToken   String?   @unique
  emailVerificationExpiry   DateTime?

  // Kundennummer für Belege (Format KD-10000)
  customerNumber   String?   @unique

  // Wallet: balance = verfügbares Guthaben (Shugyo: Aufladung/Rückerstattung; Takumi: Verdienst)
  balance          Int       @default(0)  // EUR cents (walletBalance)
  pendingBalance   Int       @default(0)  // EUR cents, Escrow bis processCompletion

  // Shugyo: Bei Rückerstattung — "payout" = Auszahlung auf Karte, "wallet" = Guthaben
  refundPreference String    @default("payout")

  // Rechnungsdaten / billingDetails: { type: "privat"|"unternehmen", ... }
  // privat: fullName, street, houseNumber, zip, city, country, email
  // unternehmen: + companyName, legalForm?, vatId?, taxNumber?, kleinunternehmer (§19 UStG)
  invoiceData      Json?

  // Shugyo: Kenntnisstufe für bessere Beratung
  skillLevel       SkillLevel?

  // Gesprochene Sprachen (z.B. ["de","en","es"]) für Fahnen-Anzeige
  languages        String[]    @default([])

  // UI-/Push-Sprache (de | en | es); synchron mit Cookie/localStorage diaiway-locale
  preferredLocale  String      @default("de")

  // Vertrauens-System: Silent-Verifizierung (Stripe, Aktivität, Admin)
  isVerified       Boolean    @default(false)
  verificationSource VerificationSource @default(NONE)

  // Session-Revokation: Unix-Timestamp; JWT mit iat < tokenRevocationTime gilt als ungültig
  tokenRevocationTime Int?

  // Moderation: Bei SafeSearch-Verstoß (Adult/Violence) in Snapshot-Moderation gesetzt
  moderationViolationAt DateTime?

  // Registrierung — Einwilligungen & Nachweis (DSGVO / Verbraucherschutz)
  /** Version der AGB zum Zeitpunkt der Zustimmung (serverseitig gesetzt, z. B. LEGAL_CONSENT_VERSION) */
  acceptedAgbVersion          String?
  acceptedAgbAt               DateTime?
  /** Datenschutzerklärung — Version & Zeitpunkt (bei kombinierter Checkbox identisch zu AGB möglich) */
  acceptedPrivacyVersion      String?
  acceptedPrivacyAt           DateTime?
  /** Shugyo: vorzeitiger Beginn / Widerrufsfolgen (§ 312g BGB) — Ausführung vor Fristende */
  earlyPerformanceWaiverAt    DateTime?
  /** Einwilligung Weitergabe Zahlungsdaten an Zahlungsdienstleister (z. B. Stripe) */
  paymentProcessorConsentAt   DateTime?
  /** Takumi: gewerblich/freiberuflich + Identitätsprüfung für Auszahlungen */
  takumiExpertDeclarationAt   DateTime?
  /** Freiwilliges Marketing — nicht vorausgewählt; Versand ggf. erst nach separatem DOI */
  marketingOptIn              Boolean    @default(false)
  marketingOptInAt            DateTime?
  marketingDoubleOptInAt      DateTime?
  /** SHA-256(IP + Pepper) — keine Klartext-IP; Pepper in REGISTRATION_IP_PEPPER / NEXTAUTH_SECRET */
  registrationIpHash          String?

  /** Shugyo: Zahlungs-/Widerrufseinwilligung (Phase 2) abgeschlossen — Voraussetzung für Buchung & Session-Start */
  isPaymentVerified           Boolean    @default(false)
  /** Phase 2: Einwilligung Weitergabe Rechnungs- & Zahlungsdaten (Zeitpunkt + IP-Hash separat von Registrierung) */
  phase2BillingConsentAt      DateTime?
  phase2BillingConsentIpHash  String?
  /** Phase 2: Widerrufsverzicht digitale Dienstleistung vor Fristende */
  phase2WithdrawalWaiverAt    DateTime?
  phase2WithdrawalWaiverIpHash String?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  expert              Expert?
  bookings            Booking[]         @relation("UserBookings")
  availability        Availability?
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  fcmTokens           FcmToken[]
  transactionsPaid   Transaction[]     @relation("UserPaidTransactions")
  walletTransactions WalletTransaction[]
  shugyoProjects      ShugyoProject[]
  takumiPortfolio     TakumiPortfolioProject[]
  sentMessages        DirectMessage[]  @relation("SentMessages")
  receivedMessages    DirectMessage[]   @relation("ReceivedMessages")
  siteAnalyticsSessions SiteAnalyticsSession[]
}

// Wallet-Bewegungen (Aufladung, Buchung, Rückerstattung) für Instant-Connect & Buchhaltung
model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents Int      // Positiv = Gutschrift, Negativ = Belastung
  type        String   // topup | deduction | booking_payment | refund | payout
  referenceId String?  // bookingId, stripeSessionId, etc.
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model ShugyoProject {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  imageUrl    String   @default("")
  createdAt   DateTime @default(now())

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String   // public key
  auth      String   // auth secret
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
}

// FCM/APNs token for native push (Capacitor)
model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  createdAt DateTime @default(now())

  @@index([userId])
}

model Expert {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  name            String
  email           String   @default("")
  avatar          String
  categorySlug    String
  categoryName    String
  subcategory     String
  bio             String
  /// Zuletzt freigegebene öffentliche Langbeschreibung (bleibt sichtbar während Bio-Nachprüfung)
  bioLive         String   @default("")
  profileReviewStatus      TakumiProfileReviewStatus @default(draft)
  profileSubmittedAt       DateTime?
  profileReviewedAt        DateTime?
  profileRejectedAt        DateTime?
  profileRejectionReason   String?                   @db.Text
  profileReviewedByUserId  String?
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  sessionCount    Int      @default(0)
  responseTime    String   @default("< 5 Min")
  // Neues Pricing-Modell: Preis pro 15 Min (EUR)
  priceVideo15Min Decimal  @default(0) @db.Decimal(10, 2)
  priceVoice15Min Decimal  @default(0) @db.Decimal(10, 2)
  pricePerSession Int?     // Legacy: EUR pro 30 Min, Fallback wenn neue Preise fehlen
  isLive          Boolean  @default(false)  // Sichtbar für Buchungen (manual)
  hideOnlineStatus Boolean @default(false)  // ON = unsichtbar; Status verbergen trotz faktisch online
  lastSeenAt      DateTime?                // Echte Präsenz; online = isLive && lastSeenAt < 5 min
  liveStatus      LiveStatus?              // Instant-Connect: offline | available | in_call | busy
  isPro           Boolean  @default(false)
  verified        Boolean  @default(false)
  portfolio       String[]
  joinedDate      String
  imageUrl        String   @default("")
  matchRate       Int      @default(0)
  // Social media links stored as JSON: { instagram, tiktok, facebook, youtube, linkedin, x, website }
  socialLinks     Json     @default("{}")
  // Cancellation policy: { freeHours: number, feePercent: number }
  // freeHours = free cancellation up to X hours before session
  // feePercent = % of booking fee retained if cancelled after free window (0–100)
  cancelPolicy    Json     @default("{\"freeHours\":24,\"feePercent\":0}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Stripe Connect für Payout-on-Demand (Takumi muss verknüpft haben)
  stripeConnectAccountId String?

  // Primäre Anzeige (Karte, Listen) — synchron zu Taxonomie bei Speichern
  primaryCategoryId  String?
  primarySpecialtyId String?
  primaryCategory    TaxonomyCategory?  @relation("ExpertPrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: SetNull)
  primarySpecialty   TaxonomySpecialty? @relation("ExpertPrimarySpecialty", fields: [primarySpecialtyId], references: [id], onDelete: SetNull)

  categoryAssignments  CategoryOnExpert[]
  specialtyAssignments SpecialtyOnExpert[]

  @@index([profileReviewStatus])
  // Relations
  bookings    Booking[]
  reviews     Review[]
  transactions Transaction[] @relation("ExpertTransactions")
}

// ─── Taxonomie (Kategorien & Fachbereiche, Admin-pflegbar) ────────────────

model TaxonomyCategory {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String   @default("")
  /** Lucide-React Icon-Name, z. B. "Wrench"; bei iconImageUrl nur Fallback */
  iconKey      String   @default("Briefcase")
  iconImageUrl String?
  color        String   @default("#64748b")
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  specialties          TaxonomySpecialty[]
  categoryOnExperts    CategoryOnExpert[]
  expertsAsPrimary     Expert[]            @relation("ExpertPrimaryCategory")
}

model TaxonomySpecialty {
  id         String   @id @default(cuid())
  categoryId String
  category   TaxonomyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  specialtyOnExperts SpecialtyOnExpert[]
  expertsAsPrimary   Expert[]            @relation("ExpertPrimarySpecialty")

  @@index([categoryId])
}

model CategoryOnExpert {
  expertId   String
  categoryId String
  expert     Expert           @relation(fields: [expertId], references: [id], onDelete: Cascade)
  category   TaxonomyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([expertId, categoryId])
  @@index([categoryId])
}

model SpecialtyOnExpert {
  expertId    String
  specialtyId String
  expert      Expert            @relation(fields: [expertId], references: [id], onDelete: Cascade)
  specialty   TaxonomySpecialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([expertId, specialtyId])
  @@index([specialtyId])
}

model TakumiPortfolioProject {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String    @default("")
  imageUrl        String    @default("")
  category        String    @default("")
  completionDate  DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId])
}

model Booking {
  id                    String        @id @default(cuid())
  expertId              String
  expert                Expert        @relation(fields: [expertId], references: [id])
  expertName            String
  expertEmail           String        @default("")
  userId                String?
  user                  User?         @relation("UserBookings", fields: [userId], references: [id])
  userName              String        @default("")
  userEmail             String        @default("")

  // Guest call fields (no account required)
  isGuestCall           Boolean       @default(false)
  guestEmail            String?
  guestToken            String?       @unique  // UUID, used as public call link

  bookingMode           BookingMode   @default(scheduled)
  date                  String        // YYYY-MM-DD (bei instant: heute)
  startTime             String        // HH:mm
  endTime               String        // HH:mm
  status                BookingStatus @default(pending)
  callType              CallType      @default(VIDEO)  // VIDEO oder VOICE
  totalPrice            Decimal?      @db.Decimal(10, 2)  // Fixierter Preis bei Buchung (EUR)
  price                 Int?          // Legacy: EUR, Fallback für Bestandsbuchungen
  note                  String        @default("")
  statusToken           String        @unique
  idempotencyKey        String?       @unique

  // Video session
  dailyRoomUrl          String        @default("")
  sessionStartedAt      DateTime?
  /** Nutzer, der die Session zuerst auf active gesetzt hat (für Partner-Push ohne Reconnect-Spam). */
  sessionOpenedByUserId String?
  sessionEndedAt        DateTime?
  sessionDuration       Int?          // minutes
  trialUsed             Boolean       @default(false)
  shugyoFrozenAt        DateTime?     // Paket 4: Soft-Freeze – Shugyo hat 0 Guthaben

  // diaiway Safety Enforcement: Pre-Call-Gateway-Zustimmung
  safetyAcceptedAt      DateTime?
  snapshotConsentAt     DateTime?  // Shugyo: Einwilligung zu Stichproben-Snapshots bei Verstößen

  // Expert's rating of the user (Shugyo) — set when Takumi rates the booker
  expertRating    Float?
  expertReviewText String?

  // Payment
  paymentStatus         PaymentStatus @default(unpaid)
  stripeSessionId       String?
  stripePaymentIntentId String?
  paidAt                DateTime?
  paidAmount            Int?          // EUR cents

  // Cancellation
  cancelledBy     String?    // "user" | "expert"
  cancelFeeAmount Int?       // EUR cents retained (only if fee applies)
  cancelledAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction     Transaction?
  safetyReports   SafetyReport[]
  safetyIncidents SafetyIncident[]
  review Review?

  @@index([expertId, date, status])
  @@index([userId])
  @@index([statusToken])
  @@index([guestToken])
}

model Review {
  id        String   @id @default(cuid())
  expertId  String
  expert    Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  userId    String
  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  rating    Float
  text      String   @default("")
  createdAt DateTime @default(now())

  @@index([expertId])
}

model Availability {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Buchbare Zeiten (geplante Termine)
  slots         Json     @default("{\"0\":[],\"1\":[],\"2\":[],\"3\":[],\"4\":[],\"5\":[],\"6\":[]}")
  yearlyRules   Json     @default("[]")
  exceptions    Json     @default("[]")
  // Instant-Call Zeiten (ohne Buchung) – wenn leer: immer wenn liveStatus=available
  instantSlots  Json     @default("{\"0\":[],\"1\":[],\"2\":[],\"3\":[],\"4\":[],\"5\":[],\"6\":[]}")
  updatedAt     DateTime @updatedAt
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // booking_request | … | booking_partner_waiting_in_call | booking_partner_joined_call | new_message
  bookingId  String?
  title      String
  body       String   @default("")
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

// Multilinguale Vorlagen für System-Mails und Waymails
model CommunicationTemplate {
  id                  String              @id @default(cuid())
  slug                String              @unique
  category            TemplateCategory
  availableVariables  Json?               // ["sender_name","recipient_name",...]
  translations        TemplateTranslation[]

  @@index([slug])
  @@index([category])
}

model TemplateTranslation {
  id         String               @id @default(cuid())
  templateId String
  template   CommunicationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  language   String               // de, en, es
  subject    String?
  body       String               @db.Text

  @@unique([templateId, language])
  @@index([templateId])
}

// Direktnachrichten: CHAT (live, nur wenn online) | MAIL/Waymail (asynchron, mit subject)
model DirectMessage {
  id                    String            @id @default(cuid())
  communicationType     CommunicationType @default(CHAT)
  senderId              String?           // null = System-Waymail (senderDisplayName)
  sender                User?             @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  senderDisplayName     String?           // "diAiway System" bei System-Waymails
  recipientId           String
  recipient             User              @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  subject               String?           // Pflicht bei MAIL
  text                  String            @db.Text
  attachmentUrl         String?
  attachmentThumbnailUrl String?
  attachmentFilename    String?
  read                  Boolean           @default(false)
  createdAt             DateTime          @default(now())

  @@index([senderId, recipientId])
  @@index([recipientId, senderId])
  @@index([recipientId, read])
  @@index([communicationType])
}

model Transaction {
  id        String            @id @default(cuid())
  bookingId String            @unique
  booking   Booking           @relation(fields: [bookingId], references: [id])
  expertId  String
  expert    Expert            @relation("ExpertTransactions", fields: [expertId], references: [id])
  userId    String            // Shugyo (Zahler)
  user      User              @relation("UserPaidTransactions", fields: [userId], references: [id])
  totalAmount Int             // EUR cents (Bruttobetrag)
  platformFee  Int            // EUR cents (15 % Provision)
  netPayout   Int             // EUR cents (für Takumi)
  status    TransactionStatus @default(AUTHORIZED)
  invoiceNumber   String?     // RE-100001 (Rechnung an Shugyo)
  creditNoteNumber String?    // GS-100001 (Gutschrift an Takumi)
  invoicePdfUrl    String?    // Rechnung diaiway → Shugyo
  creditNotePdfUrl String?    // Gutschrift diaiway → Takumi
  // Storno-Belege bei REFUNDED
  stornoInvoiceNumber    String?  // SR-100001
  stornoCreditNoteNumber String?  // SG-100001
  stornoInvoicePdfUrl    String?
  stornoCreditNotePdfUrl String?
  completedAt      DateTime?  // Capture-Zeitpunkt
  invoiceEmailSentAt    DateTime?  // Wann Rechnungs-Mail an Shugyo
  creditNoteEmailSentAt DateTime? // Wann Gutschriften-Mail an Takumi
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([expertId])
  @@index([userId])
  @@index([status])
}

// diaiway Safety Enforcement: Meldungen aus dem Call
model SafetyReport {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reporterId  String   // User, der gemeldet hat
  reportedId  String   // User/Expert, gegen den gemeldet wurde (oder beide?)
  reporterRole String  // "shugyo" | "takumi"
  reason      String?  // optional: Kategorie oder Freitext
  details     String?  @default("")
  status      String   @default("pending")  // pending | reviewed | resolved
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([bookingId])
  @@index([reporterId])
  @@index([reportedId])
  @@index([status])
}

// diaiway Safety Enforcement: KI-Alert-Snapshots bei Richtlinienverstößen (Beweissicherung)
model SafetyIncident {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  imageUrl    String   // Vercel Blob URL (bookingId_timestamp_ALARM.jpg)
  reason      String   @default("")  // z.B. "adult: LIKELY"
  status      String   @default("pending")  // pending | reviewed | blocked | refunded
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([bookingId])
  @@index([status])
}

// Admin-Aktionen (Force Capture, Manual Release) für Audit
model AdminActionLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // force_capture | manual_release
  targetType  String   // booking
  targetId    String   // bookingId
  details     Json?    @default("{}")
  createdAt   DateTime @default(now())
}

// Cron-Monitor: letzter Lauf pro Cron-Job
model CronRunLog {
  id         String   @id @default(cuid())
  cronName   String   @unique // release-wallet | experts-offline
  lastRunAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// Daily.co Ghost Session: participant.left → 60s wait for rejoin → terminate (Case A/B)
model DailyParticipantLeft {
  id          String    @id @default(cuid())
  room        String    // room-{bookingId}
  sessionId   String    // participant session_id
  leftAt      DateTime  @default(now())
  cancelledAt DateTime? // set when participant.joined (same room) within 60s → no terminate

  @@index([room])
  @@index([leftAt])
}

// Startseiten-Newsfeed (redaktionelle Pflege im Admin)
model HomeNewsItem {
  id          String    @id @default(cuid())
  linkUrl     String?
  linkLabel   String?
  published   Boolean   @default(false)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  translations HomeNewsTranslation[]

  @@index([published, sortOrder])
}

model HomeNewsTranslation {
  id         String       @id @default(cuid())
  newsItemId String
  newsItem   HomeNewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  locale     String
  title      String
  body       String       @db.Text
  /// Optional: eigener Link pro Sprache; sonst HomeNewsItem.linkUrl / linkLabel
  linkUrl    String?
  linkLabel  String?

  @@unique([newsItemId, locale])
  @@index([newsItemId])
  @@index([locale])
}

/// Anonyme Browser-Sitzungen (visitorId = LocalStorage-UUID, kein PII)
model SiteAnalyticsSession {
  id             String   @id @default(cuid())
  visitorId      String
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  startedAt      DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  /// Kumulierte Sekunden mit sichtbarem Tab (Heartbeats)
  engagedSeconds Int      @default(0)
  entryPath      String   @db.VarChar(512)
  referrer       String?  @db.VarChar(512)
  userAgent      String?  @db.VarChar(400)

  pageViews SiteAnalyticsPageView[]

  @@index([visitorId, startedAt])
  @@index([startedAt])
  @@index([userId])
}

model SiteAnalyticsPageView {
  id              String               @id @default(cuid())
  sessionId       String
  session         SiteAnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  path            String               @db.VarChar(512)
  enteredAt       DateTime             @default(now())
  durationSeconds Int                  @default(0)

  @@index([sessionId])
  @@index([path])
  @@index([enteredAt])
}

/// Admin: PDF-Branding für alle Rechnungs-/Gutschrift-PDFs (jsPDF)
model InvoiceBranding {
  id                 String   @id @default("default")
  logoUrl            String?
  accentHex          String   @default("#064e3b")
  footerText         String?  @db.Text
  paymentNote        String?  @db.Text
  closingLine        String?  @db.Text
  /// Pro Belegtyp (re_session, re_wallet, gs, sr, sg): optionale Text-Overrides
  documentTemplates  Json?
  updatedAt          DateTime @updatedAt
}

// Atomare Vergabe fortlaufender Belegnummern (RE, GS, SR, SG) und Kundennummern (KD)
model InvoiceCounter {
  id    String   @id @default(cuid())
  type  String   @unique  // "RE" | "GS" | "SR" | "SG" | "KD"
  value Int      @default(0)
  updatedAt DateTime @updatedAt
}

/// Admin-verwaltbare Textbausteine für manuelle Profil-Entziehung
model TakumiProfileRevokeSnippet {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}
